        "classes": [
            {"type_name": "电视剧", "type_id": "/browse/2.html"},
            {"type_name": "电影", "type_id": "/browse/1.html"},
            {"type_name": "短剧", "type_id": "/browse/36.html"},
            {"type_name": "动漫", "type_id": "/browse/35.html"},
            {"type_name": "综艺", "type_id": "/browse/29.html"}
        ],
        "homeJs": "let html=req.get(api).text;let doc=parseHtml(html);let list=[];doc.select('.card').each(el=>{let a=el.select('a');list.push({vod_name:el.select('h3.card__title').text(),vod_pic:el.select('img').attr('src'),vod_id:a.attr('href'),vod_remarks:el.select('.card__badge').text()});});return list;",
        "listJs": "let url=api+type_id;let html=req.get(url).text;let doc=parseHtml(html);let list=[];doc.select('.card').each(el=>{let a=el.select('a');list.push({vod_name:el.select('h3.card__title').text(),vod_pic:el.select('img').attr('src'),vod_id:a.attr('href'),vod_remarks:el.select('.card__badge').text()});});return list;",
        "searchJs": "let wd=encodeURIComponent(key);let url=api+'/search/-------------.html?wd='+wd;let html=req.get(url).text;let doc=parseHtml(html);let list=[];doc.select('.card').each(el=>{let a=el.select('a');list.push({vod_name:el.select('h3.card__title').text(),vod_pic:el.select('img').attr('src'),vod_id:a.attr('href'),vod_remarks:el.select('.card__badge').text()});});return list;",
        "detailJs": "let url=api+vod_id;let html=req.get(url).text;let doc=parseHtml(html);let playFrom=[];let playUrl=[];doc.select('.play-tab span').each(i=>playFrom.push(i.text()));doc.select('.play-list a').each(i=>playUrl.push(i.text()+'$'+i.attr('href')));return {vod_name:doc.select('h1').text(),vod_pic:doc.select('.card__thumb img').attr('src'),vod_actor:doc.select('p.card__meta').text(),vod_content:'',vod_play_from:playFrom,vod_play_url:playUrl};",
        "playJs": "var input={parse:1,url:input,js:''};return input;"
    }
